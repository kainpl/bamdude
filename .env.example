# BamDude Environment Configuration
#
# Copy this file to .env and adjust values as needed. Every variable below is
# OPTIONAL — BamDude runs out-of-the-box with no .env file at all (SQLite +
# in-tree data dir + auto-generated JWT secret). Set a variable only when you
# want to override a default or enable an optional integration.
#
# Variables fall into two groups:
#   1. Pydantic settings (DEBUG, LOG_LEVEL, LOG_TO_FILE, AUTH_REFRESH_COOKIE_SECURE)
#      — picked up by Settings() in backend/app/core/config.py.
#   2. Direct os.environ reads (everything else) — read at the call site.
#
# All bool values accept: true / false / 1 / 0 / yes / no (case-insensitive).

# =============================================================================
# Runtime
# =============================================================================

# Debug mode. true → DEBUG-level logging + auto-rerun of the latest DB migration
# on each startup (handy for migration iteration). false → INFO-level logging,
# migrations only run when version is new. Production: false.
DEBUG=false

# Log level. Used as the floor when DEBUG=false. One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Write logs to LOG_DIR/bamdude.log. Set false if you only want stdout (Docker,
# systemd-journald, etc). Daily rotation at midnight; archives land as
# bamdude-YYYY-MM-DD.log. Retention is configured in the UI under Settings ->
# Data Management (default: 7 days).
LOG_TO_FILE=true

# Uvicorn bind port. Read by Dockerfile CMD via shell expansion. Native installs
# pass --port directly to uvicorn; this var is honoured only inside the Docker
# image's CMD. (Default 8000.)
# PORT=8000

# IANA timezone. Used by container init + the support/diagnostics endpoint to
# stamp local time on bug reports. Examples: Europe/Kyiv, UTC, America/New_York.
# TZ=Europe/Kyiv

# =============================================================================
# Paths
# =============================================================================

# Data directory — SQLite DB, archives, plate-calibration refs, .jwt_secret,
# uploaded library files. Defaults to <project_root>/data on native installs;
# Docker sets it to /app/data inside the image.
# DATA_DIR=/app/data

# Log directory — where bamdude.log lives when LOG_TO_FILE=true. Defaults to
# <project_root>/logs; Docker sets it to /app/logs inside the image.
# LOG_DIR=/app/logs

# =============================================================================
# Database
# =============================================================================

# External database URL. When set, BamDude uses this instead of the default
# SQLite file at DATA_DIR/bamdude.db. PostgreSQL 14+ is the only supported
# external backend; the target database must already exist (BamDude creates
# tables but not the database itself). On first connect with an empty Postgres,
# the existing SQLite is auto-migrated into Postgres.
# DATABASE_URL=postgresql+asyncpg://bamdude:password@postgres:5432/bamdude

# =============================================================================
# Authentication & crypto
# =============================================================================

# JWT signing secret (HS256). Resolution order: this env var → DATA_DIR/.jwt_secret
# file → freshly generated 64-byte token written to .jwt_secret with mode 0600.
# Set this in multi-worker / multi-host deployments where the .jwt_secret file
# isn't shared, otherwise each worker mints incompatible tokens. Min 32 chars.
# JWT_SECRET_KEY=replace-with-a-long-random-string-min-32-chars

# Fernet key for at-rest encryption of MFA secrets (TOTP seeds, OIDC client_secrets).
# Resolution order: this env var → DATA_DIR/.mfa_encryption_key file →
# freshly generated 32-byte Fernet key written to .mfa_encryption_key with
# mode 0o600. Default-on as of 0.4.4 — there is no plaintext-by-default path.
# Generate explicitly with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When unset, BamDude auto-bootstraps a fresh key on first startup and writes
# it to .mfa_encryption_key. The key file is bundled into backup ZIPs (alongside
# bamdude.db) so a self-contained backup can be restored on a new host without
# losing access to encrypted secrets — see Settings → Backup. Existing plaintext
# rows from pre-0.4.4 installs are re-encrypted automatically on the next
# startup; an admin-only Settings UI surfaces the migration status.
# MFA_ENCRYPTION_KEY=

# Force the Secure attribute on the sliding-session refresh cookie. Default
# (unset) auto-detects from the request scheme / X-Forwarded-Proto: HTTPS gets
# Secure, plain HTTP doesn't (so dev on http://localhost actually receives the
# cookie). Force true on production HTTPS if you want belt-and-braces; false
# only for niche dev cases (defeats MITM protection).
# AUTH_REFRESH_COOKIE_SECURE=true

# Comma-separated IPs of reverse proxies that BamDude should trust for
# X-Forwarded-For resolution. Used by the auth rate-limiter to identify the
# real client IP when behind nginx / Caddy / Traefik. Multi-hop chains work:
# the rightmost XFF entry not in this set is treated as the client. Leave
# unset for direct deploys — request.client.host is used as-is.
# TRUSTED_PROXY_IPS=10.0.0.5,10.0.0.6

# Trusted iframe origins (#1191) — comma-separated list of scheme://host[:port]
# origins permitted to embed BamDude via <iframe>. Defaults to empty (strict:
# only same-origin embedding allowed via X-Frame-Options: SAMEORIGIN +
# frame-ancestors 'none'). Set this to your Home Assistant origin when using
# the HA Webpage dashboard panel: HA on :8123 and BamDude on :8000 are
# different origins to the browser, and SAMEORIGIN is port-strict so the
# default headers will refuse the embed. When set, X-Frame-Options is dropped
# entirely (legacy ALLOW-FROM is deprecated and inconsistent across vendors —
# modern browsers honour frame-ancestors which takes precedence) and the CSP
# directive becomes "frame-ancestors 'self' <list>". Wildcards, paths, query/
# fragment, and non-http(s) schemes are rejected at startup with a warning.
# TRUSTED_FRAME_ORIGINS=http://homeassistant.local:8123

# =============================================================================
# Public-facing URL (used in outbound emails)
# =============================================================================

# External base URL of this BamDude instance. Used to build absolute links in
# password-reset / MFA-recovery emails so users can click through to login.
# Falls back to http://localhost:5173 (dev frontend). The DB setting
# `external_url` overrides this when set in Settings → System.
# APP_URL=https://bamdude.example.com

# =============================================================================
# Home Assistant integration
# =============================================================================

# When BOTH HA_URL and HA_TOKEN are set, the Home Assistant integration is
# auto-enabled and the matching DB settings become read-only in the UI (the env
# values win). This is the recommended setup for the HA Add-on deployment;
# native installs can also enable HA via Settings → Integrations without env
# vars at all.
# HA_URL=http://supervisor/core
# HA_TOKEN=your-long-lived-access-token

# =============================================================================
# Virtual printer (Docker bridge mode only)
# =============================================================================

# Override the IP the embedded FTP server advertises in PASV responses. Required
# when running Docker in bridge mode (compose `ports:` instead of `network_mode:
# host`) — without this the FTP daemon advertises the container's internal IP
# and the slicer can't open the data connection. Set to the Docker host's LAN
# IP. Host-mode and native installs leave this unset.
# VIRTUAL_PRINTER_PASV_ADDRESS=192.168.1.100

# =============================================================================
# Container detection
# =============================================================================

# Either of these env vars (any non-empty value) marks the runtime as a
# container, which adjusts SSDP discovery behaviour. Normally set automatically
# by the container runtime / orchestrator — only override if you're running
# native but want container-style discovery.
# CONTAINER=1
# DOCKER_CONTAINER=1

# =============================================================================
# Docker compose helpers (read by docker-compose.yml, not by BamDude itself)
# =============================================================================

# UID / GID the bamdude container runs as. Match these to the owner of your
# mounted volumes to avoid permission errors on archive writes.
# Get them with: id -u && id -g
# PUID=1000
# PGID=1000
